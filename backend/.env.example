# ===========================================
# NEXUS AGENCY BACKEND - ENVIRONMENT VARIABLES
# ===========================================

# ─────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────

# Port on which the server will run
PORT=5000

# Environment: development, production, test
NODE_ENV=development

# Frontend URL for CORS and email links
FRONTEND_URL=http://localhost:5173

# API Base URL (for email links)
API_URL=http://localhost:5000

# ─────────────────────────────────────────
# MONGODB DATABASE CONFIGURATION
# ─────────────────────────────────────────

ACCESS_KEY=NEXUS_ADMIN_2026

# Local MongoDB (default)
MONGODB_URI=mongodb+srv://dipanshuNEXUS:098765433245@cluster0.z41iamc.mongodb.net/?appName=Cluster0

# MongoDB with authentication (if enabled)
# MONGODB_URI=mongodb://username:password@127.0.0.1:27017/nexus_db?authSource=admin

# MongoDB Atlas (Cloud) - Replace with your credentials
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexus_db?retryWrites=true&w=majority

# Docker MongoDB
# MONGODB_URI=mongodb://mongodb:27017/nexus_db

# ─────────────────────────────────────────
# JWT (JSON WEB TOKEN) CONFIGURATION
# ─────────────────────────────────────────

# Secret key for JWT signing - CHANGE THIS IN PRODUCTION!
# Use a strong, random string (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-make-it-long-and-random-123!@#

# JWT expiration time
# Format: Number (seconds) or string like '7d', '24h', '60m'
JWT_EXPIRE=7d

# Refresh token expiration (if using refresh tokens)
# JWT_REFRESH_SECRET=your-refresh-token-secret-key
# JWT_REFRESH_EXPIRE=30d

# ─────────────────────────────────────────
# PASSWORD RESET CONFIGURATION
# ─────────────────────────────────────────

# Password reset token expiration (in milliseconds)
# Default: 1 hour (3600000 ms)
RESET_TOKEN_EXPIRE=3600000

# ─────────────────────────────────────────
# EMAIL CONFIGURATION (for password reset)
# ─────────────────────────────────────────

# Gmail SMTP (most common)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-specific-password
EMAIL_FROM=Nexus Agency <noreply@nexus.com>

# Outlook/Hotmail
# EMAIL_HOST=smtp-mail.outlook.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=your-email@outlook.com
# EMAIL_PASS=your-password
# EMAIL_FROM=Nexus Agency <noreply@outlook.com>

# SendGrid (for production)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=apikey
# EMAIL_PASS=your-sendgrid-api-key
# EMAIL_FROM=Nexus Agency <noreply@yourdomain.com>

# Mailtrap (for testing - catches all emails)
# EMAIL_HOST=smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_SECURE=false
# EMAIL_USER=your-mailtrap-username
# EMAIL_PASS=your-mailtrap-password
# EMAIL_FROM=Nexus Agency <noreply@mailtrap.io>

# ─────────────────────────────────────────
# DATABASE OPTIONS
# ─────────────────────────────────────────

# MongoDB connection pool size
DB_POOL_SIZE=10

# MongoDB connection timeout (ms)
DB_CONNECTION_TIMEOUT=5000

# MongoDB socket timeout (ms)
DB_SOCKET_TIMEOUT=45000

# ─────────────────────────────────────────
# SECURITY CONFIGURATION
# ─────────────────────────────────────────

# Bcrypt salt rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW=900000  # 15 minutes in ms
RATE_LIMIT_MAX=100        # Max 100 requests per window

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session secret (if using sessions)
# SESSION_SECRET=your-session-secret

# ─────────────────────────────────────────
# LOGGING CONFIGURATION
# ─────────────────────────────────────────

# Log level: error, warn, info, debug
LOG_LEVEL=debug

# Log to file (true/false)
LOG_TO_FILE=false

# Log file path
LOG_FILE_PATH=./logs/app.log

# ─────────────────────────────────────────
# FILE UPLOAD CONFIGURATION (if needed)
# ─────────────────────────────────────────

# Maximum file upload size (in bytes)
MAX_FILE_SIZE=5242880  # 5MB

# Allowed file types
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# Upload directory
UPLOAD_DIR=./uploads

# ─────────────────────────────────────────
# THIRD-PARTY API KEYS (if needed)
# ─────────────────────────────────────────

# Stripe (for payments)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# Cloudinary (for image uploads)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ─────────────────────────────────────────
# ADMIN CONFIGURATION
# ─────────────────────────────────────────

# Default admin user (created on first run)
ADMIN_EMAIL=admin@nexus.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Admin User

# ─────────────────────────────────────────
# TESTING CONFIGURATION
# ─────────────────────────────────────────

# Test database (separate from development)
TEST_MONGODB_URI=mongodb://127.0.0.1:27017/nexus_test_db

# Test port
TEST_PORT=5001

# ─────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────

# Enable/disable features
ENABLE_EMAIL_VERIFICATION=false
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_SOCIAL_LOGIN=true
ENABLE_FILE_UPLOAD=true

# ─────────────────────────────────────────
# CACHE CONFIGURATION (Redis - if needed)
# ─────────────────────────────────────────

# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ─────────────────────────────────────────
# COMMENTS
# ─────────────────────────────────────────

# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate app-specific password at: https://myaccount.google.com/apppasswords
# 3. Use that 16-character password as EMAIL_PASS

# For production:
# - Change all secrets
# - Use strong JWT_SECRET (min 32 chars)
# - Enable email verification
# - Set NODE_ENV=production
# - Use MongoDB Atlas
# - Use SendGrid or similar email service