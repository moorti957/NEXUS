# ===========================================
# NEXUS AGENCY FRONTEND - ENVIRONMENT VARIABLES
# ===========================================

# ─────────────────────────────────────────
# API CONFIGURATION
# ─────────────────────────────────────────

# Backend API URL (without /api suffix - axios will add it)
VITE_API_URL=https://nexus-v40l.onrender.com
# Alternative: If your backend is on different port
# VITE_API_URL=http://localhost:5000

# For production (replace with your actual domain)
# VITE_API_URL=https://api.nexusagency.com

# ─────────────────────────────────────────
# APPLICATION CONFIGURATION
# ─────────────────────────────────────────

# App Name (used in meta tags, titles)
VITE_APP_NAME=Nexus Agency

# App Environment
VITE_NODE_ENV=development

# App Version
VITE_APP_VERSION=1.0.0

# ─────────────────────────────────────────
# AUTHENTICATION CONFIGURATION
# ─────────────────────────────────────────

# Token expiry check (in minutes)
VITE_TOKEN_CHECK_INTERVAL=5

# Session timeout (in minutes) - 30 minutes
VITE_SESSION_TIMEOUT=30

# ─────────────────────────────────────────
# FEATURE FLAGS
# ─────────────────────────────────────────

# Enable/disable features
VITE_ENABLE_SOCIAL_LOGIN=false
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ANIMATIONS=true
VITE_ENABLE_TOAST_NOTIFICATIONS=true

# ─────────────────────────────────────────
# API TIMEOUTS
# ─────────────────────────────────────────

# API request timeout (in milliseconds)
VITE_API_TIMEOUT=30000

# ─────────────────────────────────────────
# PAGINATION DEFAULTS
# ─────────────────────────────────────────

# Default items per page
VITE_DEFAULT_PAGE_SIZE=10

# Max items per page
VITE_MAX_PAGE_SIZE=100

# ─────────────────────────────────────────
# FILE UPLOAD LIMITS
# ─────────────────────────────────────────

# Max file size in MB
VITE_MAX_FILE_SIZE=5

# Allowed file types
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf

# ─────────────────────────────────────────
# GOOGLE ANALYTICS (Optional)
# ─────────────────────────────────────────

# Google Analytics tracking ID
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────
# SENTRY ERROR TRACKING (Optional)
# ─────────────────────────────────────────

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=https://xxxxxxxxxx@sentry.io/xxxxxx

# ─────────────────────────────────────────
# SOCIAL MEDIA LINKS
# ─────────────────────────────────────────

VITE_TWITTER_URL=https://twitter.com/nexus
VITE_LINKEDIN_URL=https://linkedin.com/company/nexus
VITE_GITHUB_URL=https://github.com/nexus
VITE_INSTAGRAM_URL=https://instagram.com/nexus

# ─────────────────────────────────────────
# CONTACT INFORMATION
# ─────────────────────────────────────────

VITE_CONTACT_EMAIL=hello@nexus.agency
VITE_CONTACT_PHONE=+1 (555) 123-4567
VITE_COMPANY_ADDRESS="548 Market St, Suite 12345, San Francisco, CA 94104"

# ─────────────────────────────────────────
# GOOGLE MAPS API (Optional)
# ─────────────────────────────────────────

# Google Maps API key for location features
# VITE_GOOGLE_MAPS_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────
# STRIPE PAYMENT (Optional)
# ─────────────────────────────────────────

# Stripe publishable key
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxx

# ─────────────────────────────────────────
# CHATBOT CONFIGURATION (Optional)
# ─────────────────────────────────────────

# Enable/disable chatbot
VITE_ENABLE_CHATBOT=false

# Chatbot API URL
# VITE_CHATBOT_API_URL=https://chatbot.nexusagency.com

# ─────────────────────────────────────────
# PERFORMANCE MONITORING
# ─────────────────────────────────────────

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=false

# ─────────────────────────────────────────
# MAINTENANCE MODE
# ─────────────────────────────────────────

# Put site in maintenance mode
VITE_MAINTENANCE_MODE=false

# Maintenance mode message
VITE_MAINTENANCE_MESSAGE="Site is under maintenance. Please check back later."

# ─────────────────────────────────────────
# COMMENTS
# ─────────────────────────────────────────

# In Vite, all environment variables must start with VITE_ to be exposed to the client
# Never store sensitive data like API keys in frontend .env files
# For production, replace values with your actual production URLs and keys